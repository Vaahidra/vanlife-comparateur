# Variables d'environnement Nuxt (côté frontend uniquement).
# Copier en `.env` à la racine de frontend/ et remplir.
#
# Les variables NUXT_PUBLIC_* sont exposées au client (browser).
# Les autres sont server-only.

# URL canonique du site (utilisée pour sitemap, OG meta, etc.)
# Local: laisser vide ou http://localhost:3000
# Prod: https://vanlife-comparateur.vercel.app (puis ton domaine .fr)
NUXT_PUBLIC_SITE_URL=

# Affiliation Amazon Partenaires France (format: xxxxxx-21)
# Voir SETUP_PHASE6_AFFILIATION.md
NUXT_PUBLIC_AMAZON_PARTNER_TAG=

# Affiliation Awin (Cdiscount, ManoMano, Decathlon, etc.)
NUXT_PUBLIC_AWIN_PUBLISHER_ID=
