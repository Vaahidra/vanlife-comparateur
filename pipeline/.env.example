# ===========================================
# IA Génération
# ===========================================
# Gemini 2.5 Flash (moteur principal, free tier généreux)
# Get: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Llama 3.3 70B (fallback gratuit)
# Get: https://console.groq.com
GROQ_API_KEY=

# ===========================================
# Publication (Nuxt + GitHub + Vercel)
# ===========================================
# Token GitHub pour push automatique des articles .md
# Get: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=
GITHUB_REPO=username/vanlife-comparateur
GITHUB_BRANCH=main

# Path local du repo cloné (pipeline écrit .md ici puis git push)
REPO_LOCAL_PATH=/Users/vaahidra/vanlife-comparateur

# Optionnel: déclenche un rebuild Vercel sans attendre commit push
# Get: Vercel Dashboard → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=

# ===========================================
# Images
# ===========================================
# Pexels (images gratuites HD)
# Get: https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash (images gratuites HD)
# Get: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ===========================================
# Affiliation
# ===========================================
# Amazon Partenaires France (format: xxxxxx-21)
# Get: https://partenaires.amazon.fr
# IMPORTANT: la même valeur DOIT aussi être dans frontend/.env :
#   NUXT_PUBLIC_AMAZON_PARTNER_TAG=xxxxxx-21
# Le composant Vue <AmazonCta> lit la version NUXT_PUBLIC pour injecter le tag dans les liens.
AMAZON_PARTNER_TAG=

# Awin Publisher ID
# Get: https://awin.com/fr
# Idem : mettre aussi NUXT_PUBLIC_AWIN_PUBLISHER_ID dans frontend/.env
AWIN_PUBLISHER_ID=

# ===========================================
# Monitoring / Alertes
# ===========================================
# Telegram bot pour notifications pipeline
# Get: BotFather sur Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# Optionnel - SEO monitoring
# ===========================================
GOOGLE_SEARCH_CONSOLE_KEY=
GOOGLE_ANALYTICS_PROPERTY_ID=
